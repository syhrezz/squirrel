# Required environment variables for Mr Squirrel backend
# Copy this file to .env and fill in the values.
# Never commit .env to version control.

# -------------------------------------------------------
# Supabase project credentials
# -------------------------------------------------------
SUPABASE_URL=https://<your-project-id>.supabase.co
SUPABASE_ANON_KEY=<your-anon-key>
SUPABASE_SERVICE_ROLE_KEY=<your-service-role-key>

# -------------------------------------------------------
# Android application configuration
# These values are read from the Flutter app at runtime.
# Store them in a secure location — NOT in version control.
# -------------------------------------------------------
FLUTTER_SUPABASE_URL=https://<your-project-id>.supabase.co
FLUTTER_SUPABASE_ANON_KEY=<your-anon-key>

# -------------------------------------------------------
# Default organization (family shop)
# -------------------------------------------------------
DEFAULT_ORGANIZATION_ID=00000000-0000-0000-0000-000000000001
DEFAULT_ORGANIZATION_SLUG=warung-mr-squirrel
